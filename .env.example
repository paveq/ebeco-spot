# 1Password secret references for `op run --env-file=.env`.
# Copy to `.env` and replace the references with your own vault/item/field
# paths (e.g. `op item get Ebeco --format json` or "Copy Secret Reference"
# in the 1Password app). Resolved at runtime; no secrets are stored here.
EBECO_EMAIL=op://Private/Ebeco/username
EBECO_PASSWORD=op://Private/Ebeco/password
